.DS_Store
.idea/
__pycache__/
*.pyc

# Rendered diagram artifacts — keep .puml sources, ignore renders
*.png
*.svg
*.pdf
!docs/**/*.png
!docs/**/*.svg
/docs/
# Local sandbox for sample skill outputs used to manually validate skills
# against open-source projects. Generated, never checked in.
docs/skill-sample-outputs/
plantuml/.claude/

# agent-ready eval viewers are regenerated by skill-creator's generate_review.py
agent-ready-workspace/iteration-*/review.html
connection-leak-workspace/iteration-*/review.html
plantuml-workspace/iteration-*/review.html
planner-observability-workspace/iteration-*/review.html

# planner-observability prototype build artifacts (regenerated by npm)
planner-observability/templates/prototype/node_modules/
planner-observability/templates/prototype/dist/
planner-observability/templates/prototype/*.tsbuildinfo
